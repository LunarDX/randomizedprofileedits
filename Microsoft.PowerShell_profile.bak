#Atmo SSH to jumpboxes
$Linux = "orugel"
$Atmo2 = "omar.rugel"

function Connect-vmw132 {
    $vmw132 = "10.156.127.4"
    ssh -oHostKeyAlgorithms=+ssh-rsa $Linux@$vmw132
}

function Connect-vmw2233 {
    $vmw2233 = '10.170.176.15'
    SSH -m hmac-sha2-256 $Atmo2@vmw2233.atmosera.com
}

# GET PUBLIC IP ADDRESS
function myip {
    param(
        [Parameter(Mandatory=$false)]
        [ValidateSet('4', '6', 'both')]
        [string]$Version = 'both'
    )
    
    try {
        if ($Version -eq '4' -or $Version -eq 'both') {
            Write-Host "[INFO] Fetching IPv4 address..." -ForegroundColor Yellow
            $ipv4 = (Invoke-RestMethod -Uri 'https://api.ipify.org?format=json' -TimeoutSec 5).ip
            
            if ($ipv4) {
                Write-Host "[IPv4] $ipv4" -ForegroundColor Green
                
                if ($Version -eq '4') {
                    $ipv4 | Set-Clipboard
                    Write-Host "[SUCCESS] IPv4 copied to clipboard!" -ForegroundColor Green
                    return $ipv4
                }
            }
        }
        
        if ($Version -eq '6' -or $Version -eq 'both') {
            Write-Host "[INFO] Fetching IPv6 address..." -ForegroundColor Yellow
            try {
                $ipv6 = (Invoke-RestMethod -Uri 'https://api64.ipify.org?format=json' -TimeoutSec 5).ip
                
                if ($ipv6 -and $ipv6 -match ':') {
                    Write-Host "[IPv6] $ipv6" -ForegroundColor Green
                    
                    if ($Version -eq '6') {
                        $ipv6 | Set-Clipboard
                        Write-Host "[SUCCESS] IPv6 copied to clipboard!" -ForegroundColor Green
                        return $ipv6
                    }
                } else {
                    Write-Host "[INFO] No IPv6 address available" -ForegroundColor Yellow
                }
            }
            catch {
                Write-Host "[INFO] IPv6 not available or timeout" -ForegroundColor Yellow
            }
        }
        
        if ($Version -eq 'both' -and $ipv4) {
            $ipv4 | Set-Clipboard
            Write-Host "[SUCCESS] IPv4 copied to clipboard!" -ForegroundColor Green
            return $ipv4
        }
    }
    catch {
        Write-Error "Failed to retrieve IP address: $($_.Exception.Message)"
    }
}

# GET LOCAL IP ADDRESSES
function localip {
    Write-Host "[INFO] Local IP Addresses:" -ForegroundColor Cyan
    
    $adapters = Get-NetIPAddress | 
        Where-Object { $_.AddressFamily -in @('IPv4', 'IPv6') -and $_.InterfaceAlias -notlike '*Loopback*' } |
        Select-Object InterfaceAlias, IPAddress, AddressFamily |
        Sort-Object AddressFamily, InterfaceAlias
    
    $adapters | Format-Table -AutoSize
    
    # Copy primary IPv4 to clipboard
    $primaryIPv4 = ($adapters | Where-Object { $_.AddressFamily -eq 'IPv4' } | Select-Object -First 1).IPAddress
    if ($primaryIPv4) {
        $primaryIPv4 | Set-Clipboard
        Write-Host "[SUCCESS] Primary IPv4 ($primaryIPv4) copied to clipboard!" -ForegroundColor Green
    }
}

function Get-RandomPassword {
    param (
        [Parameter(Mandatory=$false)]
        [int]$length = 16,
        [int]$amountOfNonAlphanumeric = 4
    )
    
    # Character sets
    $uppercase = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ'
    $lowercase = 'abcdefghijklmnopqrstuvwxyz'
    $numbers = '0123456789'
    $special = '!@#$%^&*()_+-=[]{}|;:,.<>?'
    
    # Ensure minimum length
    if ($length -lt 8) {
        $length = 8
    }
    
    # Calculate how many of each type
    $numSpecial = [Math]::Min($amountOfNonAlphanumeric, $length - 3)
    $numNumbers = [Math]::Max(1, [Math]::Floor(($length - $numSpecial) * 0.25))
    $numUpper = [Math]::Max(1, [Math]::Floor(($length - $numSpecial - $numNumbers) * 0.5))
    $numLower = $length - $numSpecial - $numNumbers - $numUpper
    
    # Generate password parts
    $password = @()
    
    # Add required characters
    for ($i = 0; $i -lt $numUpper; $i++) {
        $password += $uppercase[(Get-Random -Maximum $uppercase.Length)]
    }
    for ($i = 0; $i -lt $numLower; $i++) {
        $password += $lowercase[(Get-Random -Maximum $lowercase.Length)]
    }
    for ($i = 0; $i -lt $numNumbers; $i++) {
        $password += $numbers[(Get-Random -Maximum $numbers.Length)]
    }
    for ($i = 0; $i -lt $numSpecial; $i++) {
        $password += $special[(Get-Random -Maximum $special.Length)]
    }
    
    # Shuffle the password
    $password = $password | Sort-Object {Get-Random}
    $generatedPassword = -join $password
    
    # Copy to clipboard
    $generatedPassword | Set-Clipboard
    
    Write-Host "[SUCCESS] Password generated and copied to clipboard!" -ForegroundColor Green
    Write-Host "[PASSWORD] $generatedPassword" -ForegroundColor Yellow
    
    return $generatedPassword
}

function New-CSR {
    param (
        [Parameter(Mandatory, HelpMessage="Provide the Domain Name of the root domain being renewed")]
        [string]$DomainName,
        [Parameter(HelpMessage="Switch definition of if wildcard or not wildcard")]
        [switch]$Wildcard,
        [Parameter(Mandatory, HelpMessage="What year the renewed certificate will be valid until")]
        [int]$ExpirationYear
    )
    
    if (-NOT([Security.Principal.WindowsPrincipal][Security.Principal.WindowsIdentity]::GetCurrent()).IsInRole([Security.Principal.WindowsBuiltInRole] "Administrator")) {
        Write-Host "Administrator priviliges are required. Please restart this script with elevated rights." -ForegroundColor Red
        Pause
        Throw "Administrator priviliges are required. Please restart this script with elevated rights."
    }
    
    $UID = [guid]::NewGuid()
    $files = @{}
    $files['settings'] = "$($env:TEMP)\$($UID)-settings.inf";
    $files['csr'] = "$($env:TEMP)\$($UID)-csr.req";
    $files['key'] = "$($env:TEMP)\$($UID)-key.key"
    
    $request = @{}
    $request['SAN'] = @{}
    
    Write-Host "Provide the Subject details required for the Certificate Signing Request" -ForegroundColor Yellow
    if($WildCard) {
        $request['CN'] = '*.'+$DomainName
    } else {
        $request['CN'] = $DomainName
    }
    $request['O'] = Read-Host "Organisation (O) E.G. Atmosera Inc"
    $request['OU'] = Read-Host "Organisational Unit (OU) E.G. IT"
    $request['L'] = Read-Host "Locality / City (L) E.G. Beaverton"
    $request['S'] = Read-Host "State (S) E.G. Oregon"
    $request['C'] = Read-Host "Country Code (C); E.G. US"
    
    $i = 0
    Do {
        $i++
        $request['SAN'][$i] = read-host "Subject Alternative Name $i (e.g. alt.company.com / leave empty for none)"
        if ($request['SAN'][$i] -eq "") {}
    } until ($request['SAN'][$i] -eq "")
    
    $request['SAN'].Remove($request['SAN'].Count)
    
    $settingsInf = "
    [Version] 
    Signature=`"`$Windows NT`$ 
    [NewRequest] 
    KeyLength =  2048
    Exportable = TRUE 
    MachineKeySet = TRUE 
    SMIME = FALSE
    RequestType =  PKCS10 
    ProviderName = `"Microsoft RSA SChannel Cryptographic Provider`" 
    ProviderType =  12
    HashAlgorithm = sha256
    Subject = `"CN={{CN}},OU={{OU}},O={{O}},L={{L}},S={{S}},C={{C}}`"
    [Extensions]
    {{SAN}}
    "
    
    $request['SAN_string'] = & {
        if ($request['SAN'].Count -gt 0) {
            $san = "2.5.29.17 = `"{text}`"`n"
            Foreach ($sanItem In $request['SAN'].Values) {
                $san += "_continue_ = `"dns="+$sanItem+"&`"`n"
            }
            return $san
        }
    }
    
    $settingsInf = $settingsInf.Replace("{{CN}}",$request['CN']).Replace("{{O}}",$request['O']).Replace("{{OU}}",$request['OU']).Replace("{{L}}",$request['L']).Replace("{{S}}",$request['S']).Replace("{{C}}",$request['C']).Replace("{{SAN}}",$request['SAN_string'])
    
    $settingsInf > $files['settings']
    Clear-Host
    
    Write-Host "Certificate information
    Common name: $($request['CN'])
    Organisation: $($request['O'])
    Organisational unit: $($request['OU'])
    City: $($request['L'])
    State: $($request['S'])
    Country: $($request['C'])
    
    Subject alternative name(s): $($request['SAN'].Values -join ", ")
    
    Signature algorithm: SHA256
    Key algorithm: RSA
    Key size: 2048
    " -ForegroundColor Yellow
    
    certreq -new $files['settings'] $files['csr'] > $null
    
    $CSR = Get-Content $files['csr']
    Write-Output $CSR
    Write-Host "`n"
    
    Write-Host "Copy CSR to clipboard? (y|n): " -ForegroundColor Yellow -NoNewline
    if ((Read-Host) -ieq "y") {
        $csr | clip
        Write-Host "Check your ctrl+v`n"
    }
    
    Write-Host "Collecting Private Key information"
    $cert = Get-ChildItem Cert:\ -Recurse | ? {$_.Issuer -like "$($request['CN'])*"}
    
    $RSACng = [System.Security.Cryptography.X509Certificates.RSACertificateExtensions]::GetRSAPrivateKey($cert)
    $KeyBytes = $RSACng.Key.Export([System.Security.Cryptography.CngKeyBlobFormat]::Pkcs8PrivateBlob)
    $KeyBase64 = [System.Convert]::ToBase64String($KeyBytes, [System.Base64FormattingOptions]::InsertLineBreaks)
    
    $KeyPem = @"
-----BEGIN PRIVATE KEY-----
$KeyBase64
-----END PRIVATE KEY-----
"@
    
    New-Item -Path $files['key'] -Value $KeyPem -ItemType File
    Get-Content $files['key']
    
    [string]$Zip_Path = ($ENV:USERPROFILE+"\Documents\"+$DomainName+"_"+$ExpirationYear+".zip")
    Compress-Archive -Path $files.values -Destination $Zip_Path -CompressionLevel Optimal
    
    $files.Values | ForEach-Object {
        Remove-Item $_ -ErrorAction SilentlyContinue
    }
}

# Legacy function (kept for compatibility)
function Set-AzSubscriptionByName {
    [CmdletBinding()]
    param (
        [Parameter(Mandatory=$true, Position=0)]
        [string]$SubscriptionName
    )
    ss $SubscriptionName
}

Set-Alias -Name Switch-AzSub -Value Set-AzSubscriptionByName

#==============================================================================
# STARTUP MESSAGE
#==============================================================================
Write-Host "`n[LOADED] Azure PowerShell Profile" -ForegroundColor Green
Write-Host "[INFO] Type 'azhelp' for command reference`n" -ForegroundColor Cyan

#==============================================================================
# TERMINAL RICING (ASCII & STATS)
#==============================================================================

function Show-SystemInfo {
    $os = Get-CimInstance Win32_OperatingSystem
    $mem = Get-CimInstance Win32_PhysicalMemory | Measure-Object -Property Capacity -Sum
    $cpu = Get-CimInstance Win32_Processor | Measure-Object -Property LoadPercentage -Average
    $disk = Get-PSDrive C

    $uptime = (Get-Date) - $os.LastBootUpTime

    Write-Host "`n"
    Write-Host " ---------------------------------------------------" -ForegroundColor Cyan
    Write-Host "   OS:       $($os.Caption) ($($os.OSArchitecture))" -ForegroundColor White
    Write-Host "   Kernel:   $($os.Version)" -ForegroundColor White
    Write-Host "   Uptime:   $($uptime.TotalHours.ToString('N1')) hours" -ForegroundColor White
    Write-Host "   CPU:      $($cpu.Average)% Load" -ForegroundColor White
    Write-Host "   Memory:   $([math]::Round($mem.Sum / 1GB, 2)) GB Total" -ForegroundColor White
    Write-Host "   Disk (C): $([math]::Round($disk.Free / 1GB, 2)) GB Free / $([math]::Round($disk.Used / 1GB, 2)) GB Used" -ForegroundColor White
    Write-Host "   Theme:    $([System.IO.Path]::GetFileNameWithoutExtension($env:POSH_THEME_PATH))" -ForegroundColor Magenta
    Write-Host " ---------------------------------------------------" -ForegroundColor Cyan
    Write-Host "`n"
}

function Show-Rice {
    Show-SystemInfo
}

# Run startup info
Show-Rice
